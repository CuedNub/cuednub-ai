{
  "manifest_version": 3,
  "name": "CuedNub Ai",
  "version": "0.4.0",
  "description": "Popup manager untuk Arena AI dan Gemini dengan context menu dan kontrol keyboard.",
  "background": {
    "service_worker": "js/background.js"
  },
  "permissions": [
    "storage",
    "contextMenus",
    "tabs"
  ],
  "host_permissions": [
    "https://arena.ai/*",
    "https://*.arena.ai/*",
    "https://gemini.google.com/*"
  ],
  "action": {
    "default_title": "CuedNub Ai"
  },
  "commands": {
    "minimize-popup": {
      "description": "Minimize popup CuedNub Ai"
    },
    "restore-popup": {
      "description": "Restore dan fokuskan popup CuedNub Ai"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://arena.ai/*",
        "https://*.arena.ai/*",
        "https://gemini.google.com/*"
      ],
      "js": ["js/hint.js"],
      "run_at": "document_idle"
    }
  ]
}

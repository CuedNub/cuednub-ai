{
  "manifest_version": 3,
  "name": "CuedNub Ai",
  "version": "0.3.0",
  "description": "Popup Arena AI dengan Start, Minimize, Restore, dan Hint Mode.",
  "background": {
    "service_worker": "js/background.js"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://arena.ai/*",
    "https://*.arena.ai/*"
  ],
  "action": {
    "default_title": "Start Arena AI Popup"
  },
  "commands": {
    "minimize-arena-popup": {
      "description": "Minimize popup Arena AI"
    },
    "restore-arena-popup": {
      "description": "Restore dan fokuskan popup Arena AI"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://arena.ai/*",
        "https://*.arena.ai/*"
      ],
      "js": ["js/hint.js"],
      "run_at": "document_idle"
    }
  ]
}
